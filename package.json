{
  "name": "vital-map",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host --port 5190 --strictPort",
    "start": "npm run build && npx --yes serve dist -l tcp://0.0.0.0:5190",
    "geocode": "node scripts/geocode.mjs",
    "check-data": "node scripts/check-data.mjs"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-leaflet": "^5.0.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "@types/node": "^26.1.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
